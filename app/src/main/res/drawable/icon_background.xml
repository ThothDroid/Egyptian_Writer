<?xml version="1.0" encoding="utf-8"?>
<selector  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="false">
        <ripple android:color="@color/l_ripple_light">
            <item>
                <shape>
                    <solid android:color="@color/l_windowBackground"/>
                    <corners android:radius="8dp"/>
                    <stroke android:color="@color/l_colorPrimary"
                        android:width="1dp"/>
                </shape>
            </item>
        </ripple>
    </item>
    <item android:state_checked="true">
        <ripple android:color="@color/l_ripple_light">
            <item>
                <shape>
                    <solid android:color="@color/l_colorPrimary"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
        </ripple>
    </item>
</selector>